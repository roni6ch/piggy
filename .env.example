# Copy this file to .env.local for local development (never commit .env or .env.local with real secrets).
# .env and .env*.local are in .gitignore.

BASE_URL=http://localhost:3000
# Public site URL for canonical, OG, and sitemap (e.g. https://yourdomain.com). Update robots.txt and sitemap.xml with this domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret

# OAuth (optional)
GOOGLE_ID=
GOOGLE_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# GitHub sign-in removed; GITHUB_ID / GITHUB_SECRET no longer used

# Firebase client (analytics)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (Firestore) - path to service account JSON, or FIREBASE_SERVICE_ACCOUNT_KEY=JSON string
FIREBASE_SERVICE_ACCOUNT_PATH=

# Firebase Storage bucket for receipt uploads (optional; e.g. your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=

# Gemini (AI search agent) - optional; also accepts GIMINI_API_KEY
GEMINI_API_KEY=

# Google Places API (New) - for homepage search (e.g. "Coffee" → Aroma, Cafe Cafe). Enable Places API (New) in Google Cloud.
GOOGLE_PLACES_API_KEY=
